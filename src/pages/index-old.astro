            <div class="sf-number">26h</div>
            <div class="sf-label">Longest telecom outage duration</div>
            <div class="sf-note">Rogers Canada, July 2022</div>
          </div>
          <div class="sidebar-fact">
            <div class="sf-number">BGP</div>
