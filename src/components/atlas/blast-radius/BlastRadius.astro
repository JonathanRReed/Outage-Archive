---
type BlastLevel = {
  numeral: string;
  title: string;
  description: string;
  isRed: boolean;
};

const {
  kicker = "",
  heading = "",
  intro = "",
  insetTitle = "",
  insetSub = "",
  levels = [] as BlastLevel[],
  useDefaultEditableBinding: _useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<div class="double-rule"></div>
<div
  class="sec-masthead reveal"
  id="blast"
  {...htmlAttributes}
>
  <div
    class="sec-kicker"
    data-prop="kicker"
  >
    {kicker}
  </div>
  <h2
    class="sec-h"
    data-prop="heading"
  >
    {heading}
  </h2>
  <p
    class="sec-intro-p"
    data-prop="intro"
  >
    {intro}
  </p>
</div>
<div class="blast-section">
  <div class="blast-inset reveal">
    <div class="blast-inset-head">
      <div
        class="blast-inset-title"
        data-prop="insetTitle"
      >
        {insetTitle}
      </div>
      <div
        class="blast-inset-sub"
        data-prop="insetSub"
      >
        {insetSub}
      </div>
    </div>
    <div class="blast-spectrum-label">
      Shared dependency concentration determines how far a local incident travels
    </div>
    <div
      class="blast-row"
      role="list"
    >
      {
        levels.map((level: BlastLevel, index: number) => (
          <article
            class:list={["blast-item", level.isRed && "is-critical"]}
            role="listitem"
          >
            <div class="blast-card">
              <div class="blast-topline">
                <span class="blast-stage">Stage 0{index + 1}</span>
                <span class="blast-state">{level.isRed ? "Systemic" : "Contained"}</span>
              </div>
              <div class="blast-circle-wrap">
                <div
                  class:list={[
                    "blast-circle",
                    `b${index + 1}`,
                    level.isRed ? "b-red" : "b-default",
                  ]}
                >
                  <span class="blast-core-label">Radius</span>
                  <span class:list={["blast-num", { red: level.isRed }]}>{level.numeral}</span>
                </div>
              </div>
              <div class="blast-label-title">{level.title}</div>
              <div class="blast-label-desc">{level.description}</div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</div>

<style>
  @layer page-sections {
    .blast-section {
      padding: 0 3rem 4.5rem;
    }
    .blast-inset {
      background: var(--atlas-surface);
      border: 1px solid var(--atlas-rule);
      box-shadow: 0 22px 60px -48px rgba(13, 27, 42, 0.55);
      padding: 2.6rem 2.2rem 2.2rem;
      position: relative;
    }
    .blast-inset-head {
      margin: 0 auto 1.15rem;
      max-width: 44rem;
    }
    .blast-inset-title {
      border-bottom: 2px solid var(--atlas-deco-border);
      font-family: var(--atlas-font-display);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
      padding-bottom: 0.75rem;
      text-align: center;
      text-transform: uppercase;
    }
    .blast-inset-sub {
      color: var(--atlas-ink-muted);
      font-size: 13px;
      font-style: italic;
      margin-bottom: 0;
      text-align: center;
    }
    .blast-spectrum-label {
      color: var(--atlas-ink-faint);
      font-size: 10px;
      letter-spacing: 0.18em;
      margin: 0 auto 1.4rem;
      max-width: 44rem;
      padding: 0 1rem;
      position: relative;
      text-align: center;
      text-transform: uppercase;
    }
    .blast-row {
      align-items: stretch;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      padding-top: 0.35rem;
      position: relative;
    }
    .blast-item {
      display: flex;
      position: relative;
      text-align: center;
    }
    .blast-card {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--atlas-parchment) 16%, transparent),
        color-mix(in srgb, var(--atlas-parchment) 4%, transparent) 100%
      );
      border: 1px solid color-mix(in srgb, var(--atlas-rule) 75%, transparent);
      box-shadow: inset 0 1px 0 color-mix(in srgb, var(--atlas-parchment) 40%, transparent);
      display: flex;
      flex: 1;
      flex-direction: column;
      min-height: 100%;
      padding: 0.95rem 0.9rem 1.15rem;
      position: relative;
      text-align: center;
      z-index: 1;
    }
    .blast-topline {
      align-items: center;
      display: flex;
      gap: 0.5rem;
      justify-content: space-between;
      margin-bottom: 0.9rem;
      min-height: 1rem;
      width: 100%;
    }
    .blast-stage,
    .blast-state {
      font-size: 9px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
    .blast-stage {
      color: var(--atlas-ink-faint);
    }
    .blast-state {
      color: var(--atlas-gold);
    }
    .blast-circle-wrap {
      align-items: center;
      display: flex;
      justify-content: center;
      margin-bottom: 0.3rem;
      min-height: 8.2rem;
    }
    .blast-circle {
      align-items: center;
      background: radial-gradient(
        circle at center,
        color-mix(in srgb, var(--atlas-parchment) 60%, var(--atlas-surface)) 0%,
        transparent 72%
      );
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      height: 94px;
      justify-content: center;
      margin: 0 auto 0.75rem;
      position: relative;
      width: 94px;
    }
    .blast-circle::before,
    .blast-circle::after {
      border: 1px solid transparent;
      border-radius: 50%;
      content: "";
      inset: -8px;
      position: absolute;
    }
    .b-default {
      border: 1px solid var(--atlas-rule);
    }
    .b-red {
      border: 2px solid var(--atlas-red);
    }
    .b2::before {
      border-color: color-mix(in srgb, var(--atlas-rule) 45%, transparent);
    }
    .b3::before {
      border-color: color-mix(in srgb, var(--atlas-red) 30%, transparent);
      inset: -10px;
    }
    .b3::after {
      border-color: color-mix(in srgb, var(--atlas-red) 16%, transparent);
      inset: -20px;
    }
    .b4 {
      border-width: 3px;
    }
    .b4::before {
      border-color: color-mix(in srgb, var(--atlas-red) 34%, transparent);
      inset: -10px;
    }
    .b4::after {
      border-color: color-mix(in srgb, var(--atlas-red) 20%, transparent);
      inset: -22px;
    }
    .blast-core-label {
      color: var(--atlas-ink-faint);
      font-size: 8px;
      letter-spacing: 0.14em;
      margin-bottom: 0.2rem;
      text-transform: uppercase;
    }
    .blast-num {
      font-family: var(--atlas-font-display);
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--atlas-ink);
    }
    .blast-num.red {
      color: var(--atlas-red);
    }
    .blast-label-title {
      font-family: var(--atlas-font-display);
      color: var(--atlas-ink);
      font-size: 1rem;
      font-weight: 700;
      justify-content: center;
      line-height: 1.15;
      margin-bottom: 0.45rem;
      min-height: 2.35rem;
      display: flex;
      align-items: flex-end;
    }
    .blast-label-desc {
      color: var(--atlas-ink-muted);
      font-size: 12px;
      font-style: italic;
      line-height: 1.7;
      margin: 0 auto;
      max-width: 25ch;
    }
    .is-critical .blast-state {
      color: var(--atlas-red);
    }

    :root[data-theme="dark"] .blast-inset {
      background: #1b2d45;
      border-color: rgba(212, 175, 85, 0.2);
    }
    :root[data-theme="dark"] .blast-card {
      background: linear-gradient(180deg, rgba(10, 23, 38, 0.3), rgba(10, 23, 38, 0.12));
      border-color: rgba(212, 175, 85, 0.14);
      box-shadow: inset 0 1px 0 rgba(212, 175, 85, 0.06);
    }
    :root[data-theme="dark"] .blast-stage {
      color: #4a5a70;
    }
    :root[data-theme="dark"] .blast-state {
      color: #d4af55;
    }
    :root[data-theme="dark"] .is-critical .blast-state {
      color: #e8c96a;
    }
    :root[data-theme="dark"] .blast-core-label {
      color: #4a5a70;
    }
    :root[data-theme="dark"] .blast-num.red {
      color: #d4af55;
    }
    :root[data-theme="dark"] .b-red {
      border-color: #d4af55;
    }
    :root[data-theme="dark"] .b2::before {
      border-color: rgba(212, 175, 85, 0.16);
    }
    :root[data-theme="dark"] .b3::before {
      border-color: rgba(212, 175, 85, 0.22);
    }
    :root[data-theme="dark"] .b3::after {
      border-color: rgba(212, 175, 85, 0.12);
    }
    :root[data-theme="dark"] .b4::before {
      border-color: rgba(212, 175, 85, 0.28);
    }
    :root[data-theme="dark"] .b4::after {
      border-color: rgba(212, 175, 85, 0.15);
    }
    :root[data-theme="dark"] .blast-label-title {
      color: #f5f0e8;
    }
    :root[data-theme="dark"] .blast-label-desc {
      color: #8a9ab0;
    }

    @media (max-width: 1100px) {
      .blast-row {
        gap: 1rem;
      }
    }

    @media (max-width: 900px) {
      .blast-section {
        padding: 0 1.5rem 3rem;
      }
      .blast-inset {
        padding: 2rem 1.25rem 1.5rem;
      }
      .blast-row {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .blast-row {
        grid-template-columns: 1fr;
      }
      .blast-card {
        padding: 0.95rem 0.95rem 1.15rem;
      }
      .blast-circle-wrap {
        min-height: 7.2rem;
      }
      .blast-label-title {
        min-height: 0;
      }
    }
  }
</style>
