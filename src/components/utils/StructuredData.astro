---
export interface Props {
  site: {
    name: string;
    url?: string;
    logoSource?: string;
    description: string;
  };
}

const { site } = Astro.props;
const siteUrl = site.url || Astro.site?.toString() || "";

const structuredData: Record<string, string> = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.name,
  description: site.description,
};

if (siteUrl) {
  structuredData.url = siteUrl;
}

if (siteUrl && site.logoSource) {
  structuredData.logo = new URL(site.logoSource, siteUrl).toString();
}
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(structuredData)}
/>
